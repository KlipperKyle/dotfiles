#  -*- mode: conf-space; -*-
#
# ~/.xsettingsd
#
# This is more/less the default XFCE configuration, with some font
# tweaks.  Xsettings defaults are commented out.
#
# https://codeberg.org/derat/xsettingsd
# https://www.freedesktop.org/wiki/Specifications/XSettingsRegistry/
# https://specifications.freedesktop.org/xsettings/latest/
#

Gdk/WindowScalingFactor 1
Gtk/ButtonImages 1
# Gtk/CanChangeAccels 0
# Gtk/ColorPalette "black:white:gray50:red:purple:blue:light blue:green:yellow:orange:lavender:brown:goldenrod4:dodger blue:pink:light green:gray10:gray30:gray75:gray90"
Gtk/CursorThemeName "default"
Gtk/CursorThemeSize 16
Gtk/DecorationLayout "icon,menu:minimize,maximize,close"
Gtk/DialogsUseHeader 0
Gtk/FontName "Serif 9"
# Gtk/IconSizes ""
# Gtk/KeyThemeName ""
Gtk/MenuBarAccel "F10"
Gtk/MenuImages 1
Gtk/MonospaceFontName "Monospace 9"
Gtk/TitlebarMiddleClick "lower"
# Net/CursorBlink 1
# Net/CursorBlinkTime 1200
# Net/DndDragThreshold 8
# Net/DoubleClickDistance 5
# Net/DoubleClickTime 250
Net/EnableEventSounds 0
Net/EnableInputFeedbackSounds 0
Net/IconThemeName "Tango"
# Net/SoundThemeName "default"
Net/ThemeName "Adwaita"
# Xft/Antialias -1
# Xft/DPI -1
# Xft/Hinting -1
# Xft/HintStyle "hintnone"
# Xft/RGBA "none"
